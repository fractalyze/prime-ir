# ICICLE header-only library for CUDA MSM kernels.
# Only the headers needed for msm::msm_cuda<>() are exposed.

load("@rules_cc//cc:cc_library.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "icicle_headers",
    hdrs = glob([
        "include/icicle/**/*.h",
        "include/icicle/**/*.cuh",
    ]),
    includes = ["include"],
)

cc_library(
    name = "icicle_cuda_headers",
    hdrs = glob([
        "backend/cuda/include/**/*.h",
        "backend/cuda/include/**/*.cuh",
    ]),
    include_prefix = "third_party/icicle",
    strip_include_prefix = "backend/cuda/include",
    deps = [":icicle_headers"],
)

cc_library(
    name = "icicle_cuda_msm",
    hdrs = glob([
        "backend/cuda/src/msm/**/*.cuh",
    ]),
    include_prefix = "third_party/icicle",
    strip_include_prefix = "backend/cuda/src/msm",
    deps = [
        ":icicle_cuda_headers",
        ":icicle_headers",
    ],
)
