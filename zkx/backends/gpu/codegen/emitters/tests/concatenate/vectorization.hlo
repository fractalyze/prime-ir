// RUN: fusion_to_mlir %s | emitters_opt -zkx-gpu-test-optimize |\
// RUN:   FileCheck %s
// RUN: gpu_test_correctness %s

fusion {
  param0 = s32[640002] parameter(0)
  param1 = s32[640000] parameter(1)
  ROOT concat = s32[1280002] concatenate(param0, param1), dimensions={0}
}
// CHECK-COUNT-2: zkx.loop ({{.*}})[%{{.+}}] ->
