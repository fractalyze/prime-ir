// RUN: fusion_to_mlir %s | emitters_opt -zkx-gpu-test-optimize |\
// RUN:   FileCheck %s
// RUN: gpu_test_correctness %s

fusion {
  param0 = s32[200] parameter(0)
  param1 = s32[400] parameter(1)
  param2 = s32[300] parameter(2)
  ROOT concat = s32[900] concatenate(param0, param1, param2), dimensions={0}
}

// The first loop mapping is the same as the output indexing map so it is CSE'd.
// CHECK-DAG: #[[MAP:.*]] = #zkx.indexing_map<"(th_x, bl_x){{.*}} -> (bl_x * 128 + th_x)
// CHECK-DAG: #[[LOOPMAP_2:.*]] = #zkx.indexing_map<"(th_x, bl_x){{.*}} -> (bl_x * 128 + th_x + 200)
// CHECK-DAG: #[[LOOPMAP_3:.*]] = #zkx.indexing_map<"(th_x, bl_x){{.*}} -> (bl_x * 128 + th_x + 600)

// CHECK:       func.func @main
// CHECK-SAME:    %[[ARG_0:[a-zA-Z0-9]*]]: {{[^,]*}},
// CHECK-SAME:    %[[ARG_1:[a-zA-Z0-9]*]]: {{[^,]*}},
// CHECK-SAME:    %[[ARG_2:[a-zA-Z0-9]*]]: {{[^,]*}},
// CHECK-SAME:    %[[OUTPUT:[a-zA-Z0-9]*]]: {{[^,]*}}

// CHECK: zkx.loop ({{.*}}){{.*}} -> (%[[RA:.*]]) in #[[MAP]]
// CHECK:   %[[VAL_1:.*]] = zkx.pure_call @fusion_param0
// CHECK:   %[[INSERTED_1:.*]] = tensor.insert %[[VAL_1:.*]] into {{.*}}[%[[RA]]]

// CHECK: zkx.loop ({{.*}}){{.*}} -> (%[[RA:.*]]) in #[[LOOPMAP_2]]
// CHECK:   %[[VAL_2:.*]] = zkx.pure_call @fusion_param1
// CHECK:   %[[INSERTED_2:.*]] = tensor.insert %[[VAL_2:.*]] into {{.*}}[%[[RA]]]

// CHECK: zkx.loop ({{.*}}){{.*}} -> (%[[RA:.*]]) in #[[LOOPMAP_3]]
// CHECK:   %[[VAL_3:.*]] = zkx.pure_call @fusion_param2
// CHECK:   %[[INSERTED_3:.*]] = tensor.insert %[[VAL_3:.*]] into {{.*}}[%[[RA]]]
