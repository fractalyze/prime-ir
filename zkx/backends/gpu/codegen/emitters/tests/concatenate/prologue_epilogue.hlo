// RUN: fusion_to_mlir %s | emitters_opt -zkx-gpu-test-optimize |\
// RUN:   FileCheck %s
// RUN: gpu_test_correctness %s

fusion {
  param0 = s32[64] parameter(0)
  param1 = s32[128] parameter(1)
  neg0 = s32[64] negate(param0)
  neg1 = s32[128] negate(param1)
  concat = s32[192] concatenate(neg0, neg1), dimensions={0}
  ROOT neg = s32[192] negate(concat)
}

// CHECK: zkx.loop ({{.*}}){{.*}} -> (%[[RA:.*]]) in
// CHECK:   %[[VAL_1_1:.*]] = zkx.pure_call @fusion_neg0
// CHECK:   %[[VAL_1_2:.*]] = zkx.pure_call @fusion__epilogue__neg
// CHECK:   tensor.insert %[[VAL_1_2:.*]] into {{.*}}[%[[RA]]]

// CHECK: zkx.loop ({{.*}}){{.*}} -> (%[[RA:.*]]) in
// CHECK:   %[[VAL_2_1:.*]] = zkx.pure_call @fusion_neg1
// CHECK:   %[[VAL_2_2:.*]] = zkx.pure_call @fusion__epilogue__neg
// CHECK:   tensor.insert %[[VAL_2_2:.*]] into {{.*}}[%[[RA]]]
