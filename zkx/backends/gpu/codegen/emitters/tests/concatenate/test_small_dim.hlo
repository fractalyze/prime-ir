// RUN: fusion_to_mlir %s | FileCheck %s
// RUN: gpu_test_correctness %s

fusion {
  param0 = s32[16,16000] parameter(0)
  param2 = s32[1,16000] parameter(1)
  ROOT concat = s32[17,16000] concatenate(param0, param2), dimensions={0}
}
// Should have 2 loops.
// CHECK: zkx.loop
// CHECK: zkx.loop
