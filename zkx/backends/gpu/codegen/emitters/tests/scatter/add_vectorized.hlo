// RUN: fusion_to_mlir %s | emitters_opt -zkx-gpu-test-optimize \
// RUN:    -zkx-gpu-test-transform-loops | FileCheck %s
// RUN: gpu_test_correctness %s --bijection_inputs=scatter:2

add {
  %p0 = s32[] parameter(0)
  %p1 = s32[] parameter(1)
  ROOT %sum = s32[] add(%p0, %p1)
}
scatter {
  %operand = s32[40,1500]  parameter(0)
  %indices = s32[24,1] parameter(1)
  %update = s32[24,20,1000] parameter(2)

  ROOT %scatter = s32[40,1500] scatter(
      s32[40,1500] %operand,
      s32[24,1] %indices,
      s32[24,20,1000] %update
    ),
    update_window_dims={1,2},
    inserted_window_dims={},
    scatter_dims_to_operand_dims={0},
    index_vector_dim=1,
    unique_indices=false,
    to_apply=add
}
// CHECK: vector.transfer_read {{.*}} : tensor<480000xi32>, vector<4xi32>
