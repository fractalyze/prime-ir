// RUN: fusion_to_mlir %s | emitters_opt -zkx-gpu-test-optimize |\
// RUN:   FileCheck %s
// RUN: gpu_test_correctness %s --bijection_inputs=scatter:2

add {
  %p0 = s32[] parameter(0)
  %p1 = s32[] parameter(1)
  ROOT %sum = s32[] add(%p0, %p1)
}
scatter {
  %operand = s32[10,5]  parameter(0)
  %indices = s32[24,1] parameter(1)
  %update = s32[24,2,3] parameter(2)

  ROOT %scatter = s32[10,5] scatter(
      s32[10,5] %operand,
      s32[24,1] %indices,
      s32[24,2,3] %update
    ),
    update_window_dims={1,2},
    inserted_window_dims={},
    scatter_dims_to_operand_dims={0},
    index_vector_dim=1,
    unique_indices=false,
    to_apply=add
}
// CHECK-LABEL: func.func @main(
// CHECK-SAME:    %[[OPERAND:[a-zA-Z0-9]*]]: tensor<10x5xi32>
// CHECK-SAME:    %[[INDICES:[a-zA-Z0-9]*]]: tensor<24x1xi32>
// CHECK-SAME:    %[[UPDATES:[a-zA-Z0-9]*]]: tensor<24x2x3xi32>
// CHECK-SAME:    %[[OUT:[a-zA-Z0-9]*]]: tensor<10x5xi32>

// CHECK: %[[IN_BOUNDS:.*]] = arith.cmpi ule
// CHECK: scf.if %[[IN_BOUNDS]] -> (tensor<10x5xi32>) {
// CHECK:   zkx.loop
// CHECK:     %[[UPD_ELEM:.*]] = zkx.pure_call @scatter_update
// CHECK:     %[[RMW:.*]] = zkx.atomic_rmw %{{[a-z0-9]+}}
// CHECK:     ^bb0(%[[CUR_VALUE:.*]]: i32):
// CHECK:       %[[SUM:.*]] = arith.addi %[[CUR_VALUE]], %[[UPD_ELEM]]
// CHECK:       zkx.yield %[[SUM]] : i32
// CHECK:     }
// CHECK:     zkx.yield %[[RMW]] : tensor<10x5xi32>
