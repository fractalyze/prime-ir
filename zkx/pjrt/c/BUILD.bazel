# PJRT CPU plugin.
zkx_cc_binary(
    name = "pjrt_c_api_cpu_plugin.so",
    linkopts = select({
        "@platforms//os:macos": [],
        "//conditions:default": [
            "-Wl,--version-script,$(location :pjrt_c_api_cpu_version_script.lds)",
            "-Wl,--no-undefined",
        ],
    }),
    linkshared = True,
    tags = [
        "noasan",
        "nomsan",
        "notsan",
    ],
    deps = [
        ":pjrt_c_api_cpu",
        ":pjrt_c_api_cpu_version_script.lds",
    ],
)

