#===-------------------------------------------------------------------------------------------===//
# Code Generation
#===-------------------------------------------------------------------------------------------===//

genrule(
    name = "gen_pjrt_data_types",
    srcs = [
        "//zkx:zkx_data.proto",
        "//zkx/ffi/api:zk_dtypes_list.txt",
    ],
    outs = ["pjrt_c_api_data_types.h"],
    cmd = "$(execpath :gen_pjrt_data_types.py) $(location //zkx:zkx_data.proto) $(location //zkx/ffi/api:zk_dtypes_list.txt) $@",
    tools = [":gen_pjrt_data_types.py"],
)

