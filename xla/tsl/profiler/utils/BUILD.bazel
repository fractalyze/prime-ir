        ":math_utils",
        "@com_google_absl//absl/time",
    ],
)

zkx_cc_library(
    name = "timespan",
    hdrs = ["timespan.h"],
    deps = [
        ":math_utils",
        "@com_google_absl//absl/strings",
    ],
)

zkx_cc_library(
    name = "trace_utils",
    hdrs = ["trace_utils.h"],
    deps = ["@com_google_absl//absl/strings"],
)

zkx_cc_library(
    name = "xplane_builder",
    srcs = ["xplane_builder.cc"],
